{
  "web_player": {
    "url": "",
    "token_ttl_seconds": 86400,
    "cookie_max_age_seconds": 86400,
    "link_idle_release_seconds": 1800,
    "cookie_secure": false,
    "admin_session_ttl_seconds": 43200,
    "admin_cookie_secure": false,
    "host": "0.0.0.0",
    "port": 8080
  },
  "auto_recall": {
    "enabled": true,
    "delay": 30,
    "exclude_commands": [
      "ai_chat",
      "ai_image"
    ]
  },
  "area_join_notify": {
    "enabled": true,
    "poll_interval_seconds": 60,
    "message_template": "欢迎 {name} 加入域～",
    "message_template_leave": "{name} 已退出域",
    "auto_assign_role_id": "",
    "auto_assign_role_name": ""
  },
  "chat": {
    "enabled": true,
    "keyword_replies": {
      "你好": "你好呀！我是 Oopz Bot ~",
      "帮助": "输入 /help 查看可用命令",
      "ping": "pong!"
    }
  },
  "profanity": {
    "enabled": true,
    "mute_duration": 5,
    "warn_before_mute": true,
    "skip_admins": true,
    "context_detection": true,
    "context_window": 60,
    "context_max_messages": 10,
    "ai_detection": true,
    "ai_min_length": 2,
    "recall_message": true
  },
  "oopz": {
    "default_area": "",
    "default_channel": "",
    "proxy": "",
    "use_announcement_style": true,
    "agora_app_id": "358eebceadb94c2a9fd91ecd7b341602",
    "agora_init_timeout": 1800
  },
  "netease": {
    "base_url": "http://localhost:3000",
    "audio_download_timeout": 120,
    "audio_download_retries": 2,
    "audio_quality": "standard",
    "cookie": ""
  },
  "redis": {
    "host": "127.0.0.1",
    "port": 6379,
    "db": 0,
    "decode_responses": true
  },
  "doubao_chat": {
    "enabled": true,
    "base_url": "https://ark.cn-beijing.volces.com/api/v3",
    "model": "doubao-1-5-pro-32k-250115",
    "max_tokens": 256,
    "temperature": 0.7,
    "system_prompt": "你是 Oopz Bot，一个活泼有趣的聊天机器人。回复简洁友好，不超过100字。",
    "api_key": "",
    "context_max_rounds": 10,
    "context_ttl_seconds": 1800
  },
  "doubao_image": {
    "enabled": true,
    "base_url": "https://ark.cn-beijing.volces.com/api/v3",
    "model": "doubao-seedream-4-5-251128",
    "size": "1920x1920",
    "watermark": false,
    "api_key": ""
  },
  "music": {
    "auto_play_enabled": true,
    "default_volume": 50
  },
  "command_cooldown": {
    "enabled": false,
    "default_seconds": 3,
    "exempt_admins": true
  },
  "qq_music": {
    "enabled": false,
    "base_url": "http://localhost:3300"
  },
  "bilibili_music": {
    "enabled": false
  },
  "message_stats": {
    "enabled": true
  },
  "scheduler": {
    "enabled": true,
    "check_interval_seconds": 30
  },
  "reminder": {
    "enabled": true,
    "max_per_user": 5,
    "max_delay_hours": 72,
    "check_interval_seconds": 15
  }
